{
  "dslVersion": "1.0",
  "locale": "ru",
  "metadata": {
    "name": "[Библиотека] Сбор доказательной базы",
    "description": "Переиспользуемый под-сценарий: оператор фиксирует место, время и материальные доказательства инцидента. Используется в инцидентах, требующих расследования (драка, проникновение, саботаж).",
    "scenarioGuid": "00000000-0000-0001-0000-000000000003",
    "version": 1,
    "kind": "library",
    "demonstrates": ["multiple Image attachments", "Datetime kind=datetime", "обязательные поля для compliance"],
    "complexity": "intermediate",
    "tags": ["library", "evidence", "investigation"]
  },

  "initialStepId": "incident_time",

  "steps": [
    {
      "id": "incident_time",
      "type": "Datetime",
      "title": "Точное время",
      "view": {
        "label": "Точное время начала инцидента (по видеозаписи)",
        "kind": "datetime",
        "required": true
      },
      "transitions": { "default": { "goto": "incident_photos" } }
    },

    {
      "id": "incident_photos",
      "type": "Image",
      "title": "Снимки места",
      "view": {
        "label": "Снимки с камер: место и обстановка (минимум 3 ракурса)",
        "source": "camera",
        "allowMultiple": true,
        "required": true
      },
      "transitions": { "default": { "goto": "scene_map" } }
    },

    {
      "id": "scene_map",
      "type": "Image",
      "title": "Локация",
      "view": {
        "label": "Точка на карте объекта",
        "source": "map",
        "required": true
      },
      "transitions": { "default": { "goto": "witnesses" } }
    },

    {
      "id": "witnesses",
      "type": "Comment",
      "title": "Свидетели и обстоятельства",
      "view": {
        "label": "Свидетели, обстоятельства, дополнительные сведения для расследования",
        "placeholder": "ФИО / должности / характер обстоятельств",
        "required": true,
        "minLength": 30,
        "maxRows": 8
      },
      "transitions": { "default": { "goto": "btn_archive" } }
    },

    {
      "id": "btn_archive",
      "type": "Button",
      "title": "Архивирование",
      "view": { "label": "Сохранить в доказательную базу", "emphasis": "primary" },
      "editable": false,
      "transitions": {
        "default": {
          "actions": [
            { "type": "callMacro", "args": { "macroId": "MACRO_LOCK_VIDEO_FRAGMENT" } },
            { "type": "finish",   "args": { "resolution": "evidence_archived" } }
          ]
        }
      }
    }
  ]
}
