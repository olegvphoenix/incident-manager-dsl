{
  "dslVersion": "1.0",
  "metadata": {
    "scenarioGuid": "2dce464b-3321-7fff-86b4-2c2df06ad151",
    "version": 1,
    "name": "[A3 шаг 2] Родитель ДО inline-резолва (как лежит в scenarios.script)",
    "description": "Родительский сценарий 'Тревога периметра'. В шаге 'contact_duty' стоит ссылка type=CallScenario на дочерний сценарий 00000000-...-010. Это то, что сохраняет редактор; что хранится в scenarios.script jsonb на сервере.",
    "purpose": "architecture-demo",
    "demonstrates": [
      "исходный script с CallScenario-шагом до inline-резолва"
    ]
  },
  "initialStepId": "verify",
  "steps": [
    {
      "id": "verify",
      "type": "RadioButton",
      "view": {
        "label": "Что видно на видео?",
        "options": [
          {
            "id": "intrusion",
            "label": "Нарушитель"
          },
          {
            "id": "false",
            "label": "Ложное"
          }
        ],
        "required": true
      },
      "transitions": {
        "rules": [
          {
            "when": {
              "==": [
                {
                  "var": "state.verify.value"
                },
                "false"
              ]
            },
            "goto": "btn_close"
          }
        ],
        "default": {
          "goto": "contact_duty"
        }
      }
    },
    {
      "id": "contact_duty",
      "type": "CallScenario",
      "title": "Связь с дежурным",
      "view": {
        "scenarioGuid": "00000000-0000-0001-0000-000000000010",
        "version": 1
      },
      "transitions": {
        "default": {
          "goto": "btn_close"
        }
      }
    },
    {
      "id": "btn_close",
      "type": "Button",
      "view": {
        "label": "Закрыть",
        "emphasis": "primary"
      },
      "editable": false,
      "transitions": {
        "default": {
          "actions": [
            {
              "type": "finish",
              "args": {
                "resolution": "processed"
              }
            }
          ]
        }
      }
    }
  ]
}
