{
  "dslVersion": "1.0",
  "metadata": {
    "name": "[A3 шаг 1] Дочерний сценарий 'Связь с дежурным'",
    "description": "Это полноценный самостоятельный сценарий. Хранится в scenarios как обычная запись. ScenarioGuid 00000000-0000-0001-0000-000000000010, version 1.",
    "scenarioGuid": "00000000-0000-0001-0000-000000000010",
    "version": 1,
    "purpose": "architecture-demo"
  },
  "initialStepId": "method",
  "steps": [
    {
      "id": "method",
      "type": "RadioButton",
      "view": {
        "label": "Как удалось связаться с дежурным?",
        "options": [
          { "id": "phone",   "label": "Телефон" },
          { "id": "radio",   "label": "Рация"   },
          { "id": "no_reply","label": "Не отвечает" }
        ],
        "required": true
      },
      "transitions": {
        "default": { "goto": "decision_note" }
      }
    },
    {
      "id": "decision_note",
      "type": "Comment",
      "view": {
        "label": "Решение дежурного",
        "required": true,
        "minLength": 10
      },
      "transitions": {
        "default": { "goto": "ack" }
      }
    },
    {
      "id": "ack",
      "type": "Button",
      "view": { "label": "Связь зафиксирована", "emphasis": "primary" },
      "editable": false,
      "transitions": {
        "default": { "actions": [ { "type": "finish", "args": { "resolution": "duty_contacted" } } ] }
      }
    }
  ]
}
