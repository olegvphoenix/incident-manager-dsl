{
  "dslVersion": "1.0",
  "metadata": {
    "scenarioGuid": "8f3a8195-a80e-7f8f-8b91-10798b6760fb",
    "version": 1,
    "name": "[A3 шаг 3] Родитель ПОСЛЕ inline-резолва (как лежит в incidents.scenario)",
    "description": "Тот же родитель, но после того, как сервер развернул CallScenario при создании Incident'а. Это содержимое incidents.scenario jsonb. Runner Web/iOS/Android получает именно этот плоский граф — он НЕ ЗНАЕТ про вложенность. Сравните с файлом 2-parent-with-callscenario.json — это главное архитектурное обещание принципа П9 в действии.",
    "purpose": "architecture-demo",
    "demonstrates": [
      "результат inline-резолва: плоский граф без CallScenario",
      "префикс id = 'contact_duty' (= id исходного CallScenario-шага)",
      "точка входа: goto 'contact_duty' заменён на goto 'contact_duty__method'",
      "точка выхода: терминальный actions:[finish] дочернего ЗАМЕНЁН на goto:'btn_close' родителя",
      "runner не отличает шаги, пришедшие из дочернего, от собственных шагов родителя"
    ]
  },
  "initialStepId": "verify",
  "steps": [
    {
      "id": "verify",
      "type": "RadioButton",
      "view": {
        "label": "Что видно на видео?",
        "options": [
          {
            "id": "intrusion",
            "label": "Нарушитель"
          },
          {
            "id": "false",
            "label": "Ложное"
          }
        ],
        "required": true
      },
      "transitions": {
        "rules": [
          {
            "when": {
              "==": [
                {
                  "var": "state.verify.value"
                },
                "false"
              ]
            },
            "goto": "btn_close"
          }
        ],
        "default": {
          "goto": "contact_duty__method"
        }
      }
    },
    {
      "id": "contact_duty__method",
      "type": "RadioButton",
      "view": {
        "label": "Как удалось связаться с дежурным?",
        "options": [
          {
            "id": "phone",
            "label": "Телефон"
          },
          {
            "id": "radio",
            "label": "Рация"
          },
          {
            "id": "no_reply",
            "label": "Не отвечает"
          }
        ],
        "required": true
      },
      "transitions": {
        "default": {
          "goto": "contact_duty__decision_note"
        }
      }
    },
    {
      "id": "contact_duty__decision_note",
      "type": "Comment",
      "view": {
        "label": "Решение дежурного",
        "required": true,
        "minLength": 10
      },
      "transitions": {
        "default": {
          "goto": "contact_duty__ack"
        }
      }
    },
    {
      "id": "contact_duty__ack",
      "type": "Button",
      "view": {
        "label": "Связь зафиксирована",
        "emphasis": "primary"
      },
      "editable": false,
      "transitions": {
        "default": {
          "goto": "btn_close"
        }
      }
    },
    {
      "id": "btn_close",
      "type": "Button",
      "view": {
        "label": "Закрыть",
        "emphasis": "primary"
      },
      "editable": false,
      "transitions": {
        "default": {
          "actions": [
            {
              "type": "finish",
              "args": {
                "resolution": "processed"
              }
            }
          ]
        }
      }
    }
  ]
}
