{
  "dslVersion": "1.0",
  "metadata": {
    "scenarioGuid": "a5ad2488-55d8-7d5a-82d8-8332af443b1a",
    "version": 1,
    "name": "[A5/bad-5] Один шаг с 12 правилами вместо разбиения на шаги",
    "purpose": "anti-pattern",
    "kind": "schema-passes-but-bad-style",
    "warning": "Этот файл ВАЛИДЕН по JSON Schema. Но он демонстрирует частую ошибку: вместо разбиения логики на шаги автор пытается всё сделать в одном шаге через большой rules-массив. Минусы: (1) diff между версиями нечитаем, (2) условия сложно тестировать, (3) JSONLogic становится нечитаемым, (4) теряется визуальная декомпозиция в editor UI. Правильный паттерн: разбить на 2-3 промежуточных шага с явной семантикой. Этот случай не ловит ни схема, ни сервер — лекарство только code review.",
    "expectedRejection": "Не отвергается. Это вопрос code-review и стиля."
  },
  "initialStepId": "everything",
  "steps": [
    {
      "id": "everything",
      "type": "RadioButton",
      "view": {
        "label": "Тип события",
        "options": [
          {
            "id": "fire",
            "label": "Пожар"
          },
          {
            "id": "intrusion",
            "label": "Нарушение"
          },
          {
            "id": "panic",
            "label": "Тревожная кнопка"
          },
          {
            "id": "access",
            "label": "Контроль доступа"
          },
          {
            "id": "hardware",
            "label": "Сбой оборудования"
          },
          {
            "id": "false",
            "label": "Ложное"
          },
          {
            "id": "test",
            "label": "Тестовое"
          },
          {
            "id": "other",
            "label": "Прочее"
          }
        ],
        "required": true
      },
      "transitions": {
        "rules": [
          {
            "when": {
              "==": [
                {
                  "var": "state.everything.value"
                },
                "fire"
              ]
            },
            "actions": [
              {
                "type": "callMacro",
                "args": {
                  "macroId": "fire_evacuate"
                }
              },
              {
                "type": "escalate",
                "args": {
                  "to": "fire_brigade"
                }
              },
              {
                "type": "finish"
              }
            ]
          },
          {
            "when": {
              "==": [
                {
                  "var": "state.everything.value"
                },
                "intrusion"
              ]
            },
            "actions": [
              {
                "type": "callMacro",
                "args": {
                  "macroId": "lock_perimeter"
                }
              },
              {
                "type": "escalate",
                "args": {
                  "to": "security_chief"
                }
              },
              {
                "type": "generateReport",
                "args": {
                  "templateId": "intrusion_v2"
                }
              },
              {
                "type": "finish"
              }
            ]
          },
          {
            "when": {
              "==": [
                {
                  "var": "state.everything.value"
                },
                "panic"
              ]
            },
            "actions": [
              {
                "type": "callMacro",
                "args": {
                  "macroId": "panic_response"
                }
              },
              {
                "type": "escalate",
                "args": {
                  "to": "duty_officer"
                }
              },
              {
                "type": "finish"
              }
            ]
          },
          {
            "when": {
              "==": [
                {
                  "var": "state.everything.value"
                },
                "access"
              ]
            },
            "actions": [
              {
                "type": "assign",
                "args": {
                  "to": "access_team"
                }
              },
              {
                "type": "finish"
              }
            ]
          },
          {
            "when": {
              "==": [
                {
                  "var": "state.everything.value"
                },
                "hardware"
              ]
            },
            "actions": [
              {
                "type": "assign",
                "args": {
                  "to": "tech_support"
                }
              },
              {
                "type": "generateReport",
                "args": {
                  "templateId": "hardware_failure"
                }
              },
              {
                "type": "finish"
              }
            ]
          },
          {
            "when": {
              "==": [
                {
                  "var": "state.everything.value"
                },
                "false"
              ]
            },
            "actions": [
              {
                "type": "finish",
                "args": {
                  "resolution": "false_alarm"
                }
              }
            ]
          },
          {
            "when": {
              "==": [
                {
                  "var": "state.everything.value"
                },
                "test"
              ]
            },
            "actions": [
              {
                "type": "finish",
                "args": {
                  "resolution": "test"
                }
              }
            ]
          },
          {
            "when": {
              "==": [
                {
                  "var": "state.everything.value"
                },
                "other"
              ]
            },
            "actions": [
              {
                "type": "assign",
                "args": {
                  "to": "supervisor"
                }
              },
              {
                "type": "finish"
              }
            ]
          }
        ],
        "default": {
          "actions": [
            {
              "type": "finish"
            }
          ]
        }
      }
    }
  ]
}
