{
  "dslVersion": "1.0",
  "locale": "ru",
  "metadata": {
    "name": "[Библиотека] Запрос в техподдержку",
    "description": "Переиспользуемый под-сценарий: оператор фиксирует проблему оборудования и формирует тикет в техподдержку. Может быть запущен самостоятельно или вставлен в любой родительский сценарий через CallScenario.",
    "scenarioGuid": "00000000-0000-0001-0000-000000000002",
    "version": 1,
    "kind": "library",
    "demonstrates": ["самостоятельный сценарий, пригодный для CallScenario"],
    "complexity": "intermediate",
    "tags": ["library", "tech-support", "infrastructure"]
  },

  "initialStepId": "select_equipment",

  "steps": [
    {
      "id": "select_equipment",
      "type": "Select",
      "title": "Тип оборудования",
      "view": {
        "label": "Какое оборудование требует внимания техподдержки?",
        "options": [
          { "id": "camera",          "label": "Камера видеонаблюдения" },
          { "id": "encoder",         "label": "Видеокодер / IP-сервер" },
          { "id": "fire_sensor",     "label": "Пожарный датчик" },
          { "id": "skud_reader",     "label": "Считыватель СКУД" },
          { "id": "skud_controller", "label": "Контроллер СКУД" },
          { "id": "intercom",        "label": "Переговорное устройство" },
          { "id": "siren",           "label": "Сирена / оповещатель" },
          { "id": "other",           "label": "Другое (уточните в комментарии)" }
        ],
        "required": true
      },
      "transitions": { "default": { "goto": "problem_type" } }
    },

    {
      "id": "problem_type",
      "type": "RadioButton",
      "title": "Тип проблемы",
      "view": {
        "label": "Что именно произошло?",
        "options": [
          { "id": "offline",         "label": "Полностью недоступно" },
          { "id": "intermittent",    "label": "Работает с перебоями" },
          { "id": "image_quality",   "label": "Плохое качество изображения" },
          { "id": "hardware_damage", "label": "Видны механические повреждения" },
          { "id": "tampering",       "label": "Признаки умышленного воздействия" }
        ],
        "required": true
      },
      "transitions": {
        "rules": [
          {
            "when": { "==": [ {"var": "state.problem_type.value"}, "tampering" ] },
            "goto": "details",
            "actions": [
              { "type": "escalate", "args": { "to": "security-supervisor", "reason": "Признаки саботажа оборудования" } }
            ]
          }
        ],
        "default": { "goto": "details" }
      }
    },

    {
      "id": "details",
      "type": "Comment",
      "title": "Подробности",
      "view": {
        "label": "Опишите проблему максимально подробно (для тикета техподдержки)",
        "required": true,
        "minLength": 30,
        "maxRows": 10
      },
      "transitions": { "default": { "goto": "evidence_photo" } }
    },

    {
      "id": "evidence_photo",
      "type": "Image",
      "title": "Фото",
      "view": {
        "label": "Фото оборудования или скриншот ошибки (если применимо)",
        "source": "operator",
        "allowMultiple": true,
        "required": false
      },
      "transitions": { "default": { "goto": "btn_create_ticket" } }
    },

    {
      "id": "btn_create_ticket",
      "type": "Button",
      "title": "Создание тикета",
      "view": {
        "label": "Создать тикет в техподдержке",
        "emphasis": "primary"
      },
      "editable": false,
      "transitions": {
        "default": {
          "actions": [
            { "type": "callMacro", "args": { "macroId": "MACRO_CREATE_SUPPORT_TICKET" } },
            { "type": "finish",   "args": { "resolution": "ticket_created" } }
          ]
        }
      }
    }
  ]
}
