        "required": true,
        "minSelected": 1,
        "maxSelected": 3,
        "options": [
          { "id": "smoke",      "label": "Задымление"      },
          { "id": "smell",      "label": "Запах гари"      },
          { "id": "alarm",      "label": "Сработала сигнализация" },
