    {
      "id": "datetime_full",
      "type": "Datetime",
      "title": "Datetime, kind=datetime, с min/max",
      "view": {
        "label": "Дата и время (только в пределах суток):",
        "kind": "datetime",
        "required": true,
        "min": "2026-01-01T00:00:00",
        "max": "2026-12-31T23:59:00"
