          { "id": "f_1",       "label": "1 этаж"   },
          { "id": "f_2",       "label": "2 этаж"   },
          { "id": "f_3",       "label": "3 этаж"   },
          { "id": "f_4",       "label": "4 этаж"   },
          { "id": "f_5",       "label": "5 этаж"   },
          { "id": "f_6",       "label": "6 этаж"   },
