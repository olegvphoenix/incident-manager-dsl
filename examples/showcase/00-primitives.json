{
  "dslVersion": "1.0",
  "metadata": {
    "scenarioGuid": "04316e46-bf57-4cef-94f5-78412d0c967c",
    "version": 1,
    "name": "Витрина всех примитивов рендеринга DSL v1",
    "description": "Стартовая демонстрация: последовательно проходит через КАЖДЫЙ рендеримый тип шага DSL v1 во всех его подвариантах. Удобно начать знакомство с DSL именно отсюда, увидеть весь набор UI-элементов сразу. Используется как regression-эталон для UI-runner'ов (Web/iOS/Android): после реализации рендеринга прогонка этой витрины должна показать все экраны без ошибок. Это design-time артефакт, в продакшн-инциденты не уходит.",
    "demonstrates": [
      "Comment: readonly, обычный, многострочный (min/maxLength, min/maxRows, placeholder)",
      "RadioButton: layout=vertical и layout=horizontal",
      "Checkbox: одиночный (одна опция, как 'согласие') и группа (несколько опций, min/maxSelected)",
      "Select: короткий список и длинный список (>5 опций) с placeholder",
      "Datetime: kind=date, kind=time, kind=datetime с min/max",
      "Image: source=camera, source=map, source=operator (+ allowMultiple), source=fixed (+ fixedSrc)",
      "Button: emphasis=primary, secondary, destructive"
    ],
    "purpose": "architecture-demo",
    "category": "primitives-showcase",
    "notes": "Контент шагов намеренно нейтральный (без привязки к доменной модели инцидента). Витрина не пытается рассказать сюжет — её цель показать UI-примитивы.",
    "createdAt": "2026-04-29T00:00:00Z"
  },
  "initialStepId": "intro",
  "steps": [
    {
      "id": "intro",
      "type": "Comment",
      "title": "О витрине",
      "view": {
        "label": "Это демо-сценарий, проходящий через все примитивы DSL v1. Нажмите 'Далее' чтобы начать.",
        "readonly": true
      },
      "transitions": {
        "default": { "goto": "next_to_radios" }
      }
    },

    {
      "id": "next_to_radios",
      "type": "Button",
      "view": { "label": "Далее → RadioButton" },
      "transitions": { "default": { "goto": "radio_vertical" } }
    },

    {
      "id": "radio_vertical",
      "type": "RadioButton",
      "title": "RadioButton, layout=vertical",
      "view": {
        "label": "Выберите один вариант (вертикальная раскладка):",
        "layout": "vertical",
        "required": true,
        "options": [
          { "id": "low",    "label": "Низкий"  },
          { "id": "medium", "label": "Средний", "hint": "наиболее частый случай" },
          { "id": "high",   "label": "Высокий" }
        ]
      },
      "transitions": { "default": { "goto": "radio_horizontal" } }
    },

    {
      "id": "radio_horizontal",
      "type": "RadioButton",
      "title": "RadioButton, layout=horizontal",
      "view": {
        "label": "Выберите один вариант (горизонтальная раскладка):",
        "layout": "horizontal",
        "required": true,
        "options": [
          { "id": "yes",   "label": "Да"   },
          { "id": "no",    "label": "Нет"  },
          { "id": "skip",  "label": "Пропустить" }
